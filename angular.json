{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "GreenIsland-Online": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              "public"
            ],
            "styles": [
              "@angular/material/prebuilt-themes/indigo-pink.css",
              "node_modules/ngx-toastr/toastr.css",
              "src/assets/css/bootstrap.min.css",
              "src/assets/css/app.min.css",
              "src/assets/css/icons.min.css", 
              "node_modules/quill/dist/quill.snow.css",
              "src/styles.css"
            ],
            "scripts": [
              "src/assets/js/jquery.min.js",
              "src/assets/js/bootstrap.bundle.min.js",
              "src/assets/js/metisMenu.min.js",
              "src/assets/js/simplebar.min.js",
              "src/assets/js/waves.min.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "development"
        },
"serve": {
  "builder": "@angular/build:dev-server",
  "options": {
    "poll": 500,
    "liveReload": true
  },
  "configurations": {
    "production": {
      "buildTarget": "GreenIsland-Online:build:production"
    },
    "development": {
      "buildTarget": "GreenIsland-Online:build:development"
    }
  },
  "defaultConfiguration": "development"
},
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}